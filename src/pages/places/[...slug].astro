---
import { getCollection, render } from "astro:content";
import PlaceLayout from "../../layouts/PlaceLayout.astro";
import MonumentLayout from "../../layouts/MonumentLayout.astro";

export async function getStaticPaths() {
  const places = await getCollection("places");
  return places.map((place) => ({
    params: { slug: place.id.replace(/\/index$/, "") },
    props: { place },
  }));
}

const { place } = Astro.props;
const { Content } = await render(place);

const Layout = place.data.variant === "monument" ? MonumentLayout : PlaceLayout;
---

<Layout {...place.data}>
  <Content />
</Layout>

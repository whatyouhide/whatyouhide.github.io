---
import { Picture as AstroPicture } from "astro:assets";

type Props = {
  // Local images are imported (ImageMetadata) and optimized by astro:assets;
  // string paths (legacy posts) keep the .webp-sibling behavior.
  src: ImageMetadata | string;
  alt?: string;
  width?: string;
};

const { src, alt = "", width } = Astro.props;
const hasCaption = Astro.slots.has("default");

const isLocal = typeof src !== "string";
const m = typeof src === "string" ? src.match(/^(.+)\.(png|jpg|jpeg)$/i) : null;
const webpSrc = m ? `${m[1]}.webp` : null;
---

<figure class="place-figure" style={width ? `max-width: ${width}` : undefined}>
  {isLocal ? (
    <AstroPicture src={src} formats={["avif", "webp"]} alt={alt} loading="lazy" />
  ) : webpSrc ? (
    <picture>
      <source type="image/webp" srcset={webpSrc} />
      <img src={src} alt={alt} loading="lazy" />
    </picture>
  ) : (
    <img src={src} alt={alt} loading="lazy" />
  )}
  {hasCaption && <figcaption><slot /></figcaption>}
</figure>

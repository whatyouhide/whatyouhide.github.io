---
import BaseLayout from "./BaseLayout.astro";

type Props = {
  title: string;
  subtitle?: string;
  date?: Date;
  countryName: string;
  flag?: string;
  placeClass?: string;
};

const { title, subtitle, date, countryName, flag, placeClass } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  month: "long",
  year: "numeric",
});
---

<BaseLayout title={title} description={`${title} — a place note.`}>
  <main class={`place-page${placeClass ? ` ${placeClass}` : ""}`}>
    <section class="place-hero">
      <div class="place-hero-flag">
        {flag && <span class="place-hero-flag-emoji">{flag}</span>}
        <span>{countryName}</span>
      </div>
      <h1>
        {title}
        {subtitle && <em>{subtitle}</em>}
      </h1>
      {date && <div class="place-hero-date">{dateFormatter.format(date)}</div>}
    </section>

    <div class="place-band"><div class="place-band-inner"></div></div>

    <article class="place-content">
      <slot />
    </article>
  </main>
</BaseLayout>
